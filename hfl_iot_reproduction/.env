# Simulação
SIM_ROUNDS=80
LOCAL_EPOCHS=2
LR=0.001
BATCH_SIZE=64
OPTIMIZER=adam
CLIP_NORM=1.0

# MQTT (comunicação entre camadas)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_BASE_TOPIC=hfl
MQTT_QOS=1
MQTT_KEEPALIVE=60

# Edge (agregação assíncrona)
SW_INIT=7
PDESIRED=0.75
ALPHA_SW=0.5
ALPHA_EDGE=0.7
BETA_EDGE=0.3

# Cloud (ponderação p vs q)
BETA_CLOUD=0.5
GAMMA_EDGE=0.9
Q_FIXED=1.0

# Targets por edge (modelo global separado por tarefa)
EDGE1_TARGET=temp
EDGE2_TARGET=humidity
EDGE3_TARGET=light

# Distilação (teacher -> student)
DISTILL_ALPHA=0.1
DISTILL_ALPHA_DYNAMIC=1

# Readiness barrier
CLOUD_WAIT_FOR_EDGES=1
CLOUD_EXPECTED_EDGES=edge1,edge2,edge3
EDGE_WAIT_FOR_IOTS=1
EDGE_WAIT_FOR_CLOUD=1
EDGE1_EXPECTED_IOTS=iot1,iot2
EDGE2_EXPECTED_IOTS=iot3,iot4
EDGE3_EXPECTED_IOTS=iot5,iot6
IOT_WAIT_FOR_READY=1

# Teacher (cloud)
TEACHER_ENABLE=1
TEACHER_EPOCHS=20
TEACHER_BATCH=128
TEACHER_LR=0.0005
TEACHER_MAX_SAMPLES=0
TEACHER_REFRESH_EVERY=0
TEACHER_PUSH_INIT=1
TEACHER_PUSH_EVERY=10

# Edge fine-tuning (student on proxy data)
EDGE_FT_EPOCHS=2
EDGE_FT_BATCH=128
EDGE_FT_EVERY=1
EDGE_FT_MAX_SAMPLES=0
EDGE_FT_ALPHA=0.1

# Server-side fine-tuning (cloud student on proxy data)
SERVER_FT_EPOCHS=3
SERVER_FT_BATCH=128
SERVER_FT_EVERY=1
SERVER_FT_MAX_SAMPLES=0
SERVER_FT_ALPHA=0.3

# Edge aggregation weighting
EDGE_WEIGHT_BY_SAMPLES=1

# Modelos por camada
STUDENT_MODEL_TYPE=mlp
CLOUD_TEACHER_MODEL_TYPE=tcn
EDGE_TEACHER_MODEL_TYPE=gru

# Student (IoT/Edge): MLP pequena (TinyML)
STUDENT_MLP_UNITS=64,32
STUDENT_MLP_DROPOUT=0.05

# Edge teacher (moderado)
EDGE_TEACHER_ENABLE=1
EDGE_TEACHER_EPOCHS=5
EDGE_TEACHER_BATCH=128
EDGE_TEACHER_LR=0.001
EDGE_TEACHER_MAX_SAMPLES=0
EDGE_TEACHER_REFRESH_EVERY=0
EDGE_DISTILL_SOURCE=auto
EDGE_GRU_UNITS=32,32
EDGE_GRU_DROPOUT=0.1
EDGE_GRU_DENSE=32

# Teacher (Cloud): TCN super (robusta)
CLOUD_TCN_FILTERS=128
CLOUD_TCN_KERNEL=3
CLOUD_TCN_DILATIONS=1,2,4,8,16,32
CLOUD_TCN_DROPOUT=0.2
CLOUD_TCN_DENSE=256

# Loss
LOSS_FN=huber
HUBER_DELTA=1.0
LOSS_FN_CLASSIF=binary_crossentropy

# Heterogeneidade (delays em segundos ~ N(mu, sigma))
IOT_DELAY_MU=1.2
IOT_DELAY_SIGMA=0.8

# Seeds
GLOBAL_SEED=42

# Criptografia (chaves de exemplo; troque em prod)
IOT_KEY_HEX=00112233445566778899AABBCCDDEEFF00112233445566778899AABBCCDDEEFF
EDGE1_KEY=00112233445566778899AABBCCDDEEFF
EDGE2_KEY=0102030405060708090A0B0C0D0E0F10
EDGE3_KEY=11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF

# Opcional: salvar pesos globais para análise por target
SAVE_GLOBAL_WEIGHTS=1
SAVE_GLOBAL_WEIGHTS_EVERY=1
